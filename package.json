{
  "name": "famimport",
  "version": "0.1.0",
  "private": true,
  "description": "Vérification et correction des codes HS (Tarabel) pour imports Chine→Belgique",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "web": "node --import tsx src/server.ts",
    "cli": "node --import tsx src/index.ts",
    "ingest": "node --import tsx src/ingest-catalog.ts",
    "ingest-customs": "node --import tsx src/ingest-customs.ts",
    "ingest-tarbel": "node --import tsx src/ingest-tarbel.ts",
    "push-nomenclature": "node --import tsx src/push-nomenclature.ts",
    "stats": "node --import tsx src/catalog-stats.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "pdfjs-dist": "^6.0.227",
    "tar": "^7.5.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0"
  }
}
