# --- API Claude (pour Vague 2.5+) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-7

# --- Authentification web (Railway) ---
# Mot de passe partagé pour accéder à l'app
APP_PASSWORD=change-me-please
# Secret HMAC pour signer les cookies de session (générer une chaîne aléatoire de 32+ chars)
SESSION_SECRET=change-me-to-a-random-string

# --- Chemins de stockage ---
# En local: défaut = ./catalog
# Sur Railway: monter un volume sur /data et mettre DATA_ROOT=/data
DATA_ROOT=./catalog
# (ou surcharges fines:)
# DB_PATH=/data/catalog.db
# PHOTOS_DIR=/data/photos
# UPLOADS_DIR=/data/uploads
# UPLOAD_PHOTOS_DIR=/data/upload-photos

# --- Serveur ---
PORT=3050
NODE_ENV=development
